{
  "//": "Harness-enforced behavior for orionfold-proof. Allow-rules widen what runs without prompting; keep them tight. The PreToolUse hook enforces the no-secrets prime directive. See settings.json.example for the reviewed template; see docs/tech/global-skills-inventory.md for the plugin/skill rationale.",
  "model": "claude-opus-4-8",
  "permissions": {
    "allow": [
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run pyright:*)",
      "Bash(uv sync:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm exec playwright:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(uv add:*)",
      "Bash(pnpm add:*)",
      "Bash(uv tool install:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(./**/.env)",
      "Read(./**/.env.*)"
    ]
  },
  "enabledPlugins": {
    "stripe@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "session-report@claude-plugins-official": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/secrets-guard.py\""
          }
        ]
      }
    ]
  }
}
